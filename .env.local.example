# ============================================================
# Financiare – Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service Role Key — usado apenas no servidor (nunca expor no cliente)
# Encontre em: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# URL pública do app (para magic links em produção)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
